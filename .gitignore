# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Firebase platform config. Android now selects its project at runtime via
# explicit options in lib/core/config/firebase_env_options.dart, so no
# google-services.json is baked in. iOS still uses a bundled plist (kept out
# of git to avoid repeat secret-scanner alerts).
/android/app/google-services.json
/ios/Runner/GoogleService-Info.plist
